  "flow": {
    "intercept": "Hero.try_interceptвҶ’RayCast2DвҶ’Enemy.set_paused(true)вҶ’both_ATTACKвҶ’Hero.frame2_deal_dmg; Enemy.attack_hit_signalвҶ’Hero.take_damage",
    "deploy": "CardUI.drag_endedвҶ’BattleTest._deploy_hero_from_cardвҶ’BattleManager.apply_displacement(recursive_max5)вҶ’tween_0.25s",
    "deadlock": "DeckManager._physics_process(1s)вҶ’hand0+queue0+field0вҶ’rescue_pkgвҶ’GameEvents.deadlock_rescue_triggeredвҶ’BattleUI.banner",
    "death": "HPвүӨ0вҶ’DEATH_stateвҶ’play_deal_frames_onceвҶ’tween_fadeoutвҶ’queue_free",
    "victory": "WaveDirector._check_victory(all_spawned+alive=0)вҶ’GameEvents.stage_victoryвҶ’BattleTest._on_stage_victoryвҶ’BattleManager.show_settlement(true)вҶ’VictoryPanel.tscn",
    "defeat": "BattleTest._trigger_game_overвҶ’GameEvents.game_overвҶ’BattleTest._on_game_overвҶ’BattleManager.show_settlement(false)вҶ’DefeatPanel.tscn",
    "settlement": "show_settlementвҶ’иҜ»DataManager.rewardsвҶ’CanvasLayer+set_scriptвҶ’_build_uiд»Јз Ғжһ„е»әвҶ’setupвҶ’еҠЁз”»вҶ’tween.finishedвҶ’time_scale=0"
  },
  "pitfalls": {
    "title": "GodotејҖеҸ‘и§„иҢғ/йҒҝеқ‘жҢҮеҚ—",
    "rules": [
      {
        "id": "PIT-001",
        "tag": "UIжҢӮиҪҪиҠӮзӮ№",
        "rule": "е…ЁеұҖ VFX зҡ„ CanvasLayer з»қеҜ№дёҚиғҪдҪңдёә Window/Autoload зҡ„еӯҗиҠӮзӮ№гҖӮAutoload жҳҜ Window зҡ„зӣҙжҺҘеӯҗиҠӮзӮ№пјҢдёҚеңЁ 2D Viewport жёІжҹ“еӯҗж ‘еҶ…пјҢе…¶еӯҗ CanvasLayer дёҚдјҡжёІжҹ“гҖӮеҝ…йЎ»жҢӮиҪҪеҲ° camera.get_parent()пјҲеҚі 2D Viewport жёІжҹ“еӯҗж ‘еҶ…зҡ„иҠӮзӮ№пјҢеҰӮ BattleTestпјүгҖӮ",
        "code": "_damage_canvas = CanvasLayer.new(); camera.get_parent().add_child(_damage_canvas)"
      },
      {
        "id": "PIT-002",
        "tag": "еқҗж ҮиҪ¬жҚўе…¬ејҸ",
        "rule": "дё–з•Ңеқҗж ҮиҪ¬ UI з”»еёғеқҗж ҮпјҢеҝ…йЎ»дёҘж јдҪҝз”Ё get_canvas_transform().affine_inverse() * world_posгҖӮcanvas_transform зҡ„ж–№еҗ‘жҳҜ canvasвҶ’worldпјҢеҸ–йҖҶжүҚжҳҜ worldвҶ’canvasгҖӮз»қдёҚиғҪз”Ёй”ҷзҹ©йҳөж–№еҗ‘пјҢеҗҰеҲҷеқҗж Үе®Ңе…ЁеҒҸз§»гҖӮ",
        "code": "screen_pos = camera.get_canvas_transform().affine_inverse() * world_pos"
      },
      {
        "id": "PIT-003",
        "tag": "UIе°әеҜёеҹәеҮҶ",
        "rule": "жң¬йЎ№зӣ®и®ҫи®Ўй«ҳеәҰ 2160pxгҖӮжүҖжңүеҠЁжҖҒз”ҹжҲҗзҡ„ Label ж–Үжң¬еӯ—еҸ·еҹәеҮҶдёҚеҫ—е°ҸдәҺ 36pxпјҢжҸҸиҫ№ outline_size иҮіе°‘дёә 3гҖӮиӢҘе°ҸдәҺжӯӨеҹәеҮҶпјҢеңЁй«ҳеҲҶиҫЁзҺҮдёӢж–Үеӯ—иӮүзңјдёҚеҸҜи§ҒгҖӮ",
        "code": "label.add_theme_font_size_override(\"font_size\", 36); label.add_theme_constant_override(\"outline_size\", 3)"
      }
    ]
  }
}
