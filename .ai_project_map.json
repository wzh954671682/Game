{
  "v": 1,
  "engine": "godot4.6",
  "name": "GameDemo-w",
  "resolution": [1080, 2160],
  "dirs": {
    "scripts": "Scripts",
    "scenes": "Scenes",
    "assets": "Assets",
    "data": "Data",
    "maps": "BattleMap",
    "docs": "Docs",
    "tools": "Tools"
  },
  "al": [
    {"n": "GameEvents", "f": "Scripts/Global/GameEvents.gd", "r": "sigbus"},
    {"n": "GridManager", "f": "Scripts/Logic/GridManager.gd", "r": "grid"},
    {"n": "DataManager", "f": "Scripts/Global/DataManager.gd", "r": "json"},
    {"n": "BattleManager", "f": "Scripts/Managers/BattleManager.gd", "r": "occ"},
    {"n": "DeckManager", "f": "Scripts/Managers/DeckManager.gd", "r": "deck"},
    {"n": "VFXManager", "f": "Scripts/Global/VFXManager.gd", "r": "vfx"},
    {"n": "SaveManager", "f": "Scripts/Global/SaveManager.gd", "r": "save"},
    {"n": "EffectResolver", "f": "Scripts/Logic/EffectResolver.gd", "r": "effect"},
    {"n": "HeroProjectile", "f": "Scripts/Entities/HeroProjectile.gd", "r": "proj"}
  ],
  "gd": {
    "Scripts/Logic/EffectResolver.gd": {
      "ext": "Node",
      "m": ["get_card_data", "card_type_from_id", "resolve_targets", "execute_card", "_exec_passive_atk_speed_stack", "_exec_passive_generic"],
      "note": "卡牌效果解析器: 目标校验+action_list分发, 17种action类型(全部实装)"
    },
    "Scripts/Entities/HeroProjectile.gd": {
      "ext": "Area2D",
      "exp": [],
      "m": ["setup", "_on_hit"],
      "note": "弹道: 穿透衰减(_pierce_decay)+目标去重(_hit_targets)+暴击传递; 支持序列帧或单图"
    }, {
      "ext": "Node2D",
      "fsm": ["STANDBY", "ATTACK", "DEATH"],
      "exp": ["hero_id", "current_star", "max_block_count", "attack_power", "max_health", "frame_interval", "attack_range", "heal_percent", "heal_interval", "heal_aura_scale", "_atk_speed_stacks", "hp_bar_show", "hp_bar_y_offset", "hp_bar_width", "hp_bar_height", "hp_bar_bg_color", "hp_bar_fill_color"],
      "sig": [],
      "m": ["try_intercept", "take_damage", "can_star_up", "star_up", "init_hero", "set_paused", "get_final_stats", "apply_permanent_buff", "apply_timed_buff", "apply_passive", "_trigger_attack_passives", "_roll_crit", "_spawn_burning_ground", "_trigger_mark_detonate", "_trigger_atk_speed_stack", "_on_atk_speed_decay", "_on_enemy_attack_hit", "heal", "set_dimmed", "_setup_hp_bar", "_update_hp_bar", "_setup_hitbox", "_setup_heal_aura", "_heal_nearby_allies", "_pulse_heal_aura"],
      "stars": { "max": 5, "mult": [1.0, 1.5, 2.2, 3.0, 4.5], "scale": 0.1, "heal": 0.2 },
      "sprites": { "shielder_01": "001", "hero_002": "001", "hero_003": "001", "hero_004": "001" },
      "z": { "default": 0 },
      "note": "HPBar: 角色下方80px @export可调; 属性4维(atk/hp/atk_speed/crit_rate); 暴击2x+穿透衰减+印记引爆+燃烧区域+治疗光环+Hitbox(80x120)"
    },
    "Scripts/Entities/Enemy.gd": {
      "ext": "Area2D",
      "fsm": ["MOVE", "ATTACK", "DEATH"],
      "exp": ["move_speed", "max_health", "wall_damage", "attack_damage", "monster_id", "frame_interval", "is_elite", "is_boss", "can_strafe", "bypass_intercept", "explosion_damage", "explosion_radius", "hp_bar_show", "hp_bar_y_offset", "hp_bar_width", "hp_bar_height", "hp_bar_bg_color", "hp_bar_fill_color"],
      "sig": ["attack_hit"],
      "m": ["take_damage", "set_paused", "freeze", "add_mark", "clear_marks", "_setup_hp_bars", "_update_strafe", "_trigger_explosion"],
      "z": { "default": 0 },
      "note": "HPBar: 头顶60px, 全敌人显示; 色值bg#161616 fill#fdd211; 印记系统(add_mark/clear_marks); take_damage支持is_crit暴击"
    },
    "Scripts/Global/GameEvents.gd": {
      "ext": "Node",
      "sig": ["wall_hit", "enemy_died", "card_deployed", "deadlock_rescue_triggered", "wall_hp_changed", "game_over", "stage_victory"]
    },
    "Scripts/Global/DataManager.gd": { "ext": "Node", "m": ["load_json"], "exp": ["error_messages", "monster_templates", "stage_config", "wall_config", "rarity_config", "card_display_config", "heroes_progression", "card_actions_config"] },
    "Scripts/Global/SaveManager.gd": { "ext": "Node", "m": ["save_game", "load_game"], "exp": ["save_data(gold/shards/max_level/selected_level/selected_stage/unlocked_cards)"] },
    "Scripts/Global/VFXManager.gd": { "ext": "Node", "m": ["hit_stop", "show_damage_text", "play_skill_vfx"], "note": "PROCESS_MODE_ALWAYS; Phase15.5: is_crit参数(黄字/1.5x字号/弹性缩放), 防堆叠(POPUP_MAX=15, >5屏偏移)", "z": { "damage_text": 20, "damage_canvas_layer": 100 } },
    "Scripts/Logic/GridManager.gd": {
      "ext": "Node",
      "m": ["get_screen_pos", "get_logic_pos", "get_wall_boundary", "get_card_tray_top", "apply_scene_layout", "set_grid_anchor_pos", "get_grid_center", "setup_map", "load_battle_map", "load_map_async", "get_tile_node", "get_tile_for_grid_pos"],
      "c": { "cols": 5, "rows": 5, "cell": 190, "rw": 1080, "rh": 2160, "tile_count": 25, "tile_z_index": -5 }
    },
    "Scripts/Managers/BattleManager.gd": {
      "ext": "Node",
      "m": ["apply_displacement", "register_entity", "unregister_entity", "get_hero_at", "_on_displacement_finished", "show_settlement"],
      "c": { "max_recurse": 5, "tween_dur": 0.25 },
      "exp": ["current_stage_id"],
      "note": "Phase16: show_settlement→load .tscn→setup→动画→tween.finished→time_scale=0"
    },
    "Scripts/Logic/WaveDirector.gd": {
      "ext": "Node",
      "r": "wave",
      "m": ["load_stage_script", "get_map_id", "is_last_wave", "is_active", "_spawn"],
      "exp": [],
      "sig": [],
      "c": {},
      "note": "spawn传递全部模板属性: strafe/bypass/explosion; SPAWN_OFFSET=-430; stage_elapsed起始=-2s"
    },
    "Scripts/Managers/DeckManager.gd": {
      "ext": "Node",
      "sig": ["card_drawn"],
      "c": { "max_hand": 5, "rescue_cd": 10, "draw_interval": 0.1, "scan_interval": 1.0, "init_silence": 5.0 },
      "m": ["start_battle", "on_effect_used"]
    },
    "Scripts/UI/BattleUI.gd": { "ext": "CanvasLayer", "m": ["update_exp", "update_battle_level", "_on_pause_pressed"], "exp": ["_medal_bg", "_battle_level_label", "_exp_progress_bar", "_exp_label", "_pause_button", "_pause_panel"], "note": "TopWrapper子节点引用+暂停面板加载" },
    "Scripts/UI/PausePanel.gd": { "ext": "CanvasLayer", "m": ["show_pause", "_on_continue_pressed", "_on_home_pressed"], "note": "暂停弹窗: 遮罩+继续(取消暂停)+首页(change_scene→MainScene)" },
    "Scripts/UI/CardTrayManager.gd": { "ext": "Control", "cn": "CardTrayManager", "sig": ["card_created"], "m": ["setup"], "c": { "CARD_W": 195, "CARD_H": 260, "SPACING": 195, "SLIDE_DUR": 0.3, "FLY_IN_DUR": 0.25, "PUSH_DUR": 0.18, "PUSH_OFFSET": 52, "MAX_VISIBLE": 5 } },
    "Scripts/UI/CardUI.gd": { "ext": "Control", "sig": ["drag_started", "drag_ended", "drag_cancelled"], "m": ["setup_card", "setup", "_fit_label_font"], "z": { "idle": 0, "dragging": 10, "selected": 10 }, "c": { "LABEL_DEFAULT_FONT_SIZE": 42, "LABEL_MIN_FONT_SIZE": 24 }, "note": "数据驱动: setup_card()→rarity_config+card_display_config→动态加载CardBG/Icon/Label; _fit_label_font自适应字号42→24" },
    "Scripts/UI/MainScene.gd": { "ext": "CanvasLayer", "m": ["switch_panel", "_on_nav_button_pressed", "_on_start_battle_pressed", "_populate_hero_panel", "_populate_hero_list", "_on_card_drag_ended", "_assign_to_squad", "_load_squad_from_save", "_show_hero_in_slot", "_show_empty_slot", "_on_level_left_pressed", "_on_level_right_pressed", "_refresh_level_display"], "exp": ["panels[5]", "nav_buttons[5]", "squad_slots[4]", "hero_list_content(HBoxContainer)", "_hero_list_populated", "_level_label", "_btn_level_left", "_btn_level_right", "_current_level_index", "_total_levels"], "c": { "PANEL_SHOP": 0, "PANEL_HERO": 1, "PANEL_BATTLE": 2, "PANEL_CAMP": 3, "PANEL_GUILD": 4 }, "note": "NavBar+关卡选择(LevelSelect: BtnLevelLeft/LevelLabel/BtnLevelRight), 选中态StyleBoxFlat(#9de38c)+font_disabled(#161616)" },
    "Scripts/UI/SafeAreaContainer.gd": { "ext": "MarginContainer" },
    "Scripts/UI/WrapperMonitor.gd": { "ext": "Control", "note": "Debug: 监控Wrapper节点size/position变化并打印日志" },
    "Scripts/UI/SettlementPanel.gd": {
      "ext": "CanvasLayer",
      "m": ["setup", "_play_entrance_animation", "_create_reward_icons", "_make_reward_item", "_save_rewards", "_on_btn_action_pressed"],
      "exp": ["entrance_duration", "item_bounce_duration", "item_delay", "freeze_delay", "victory_color", "defeat_color", "overlay_color", "gold_color", "shard_color"],
      "c": { "coin_icon": "Assets/UI/item/jinbi.png", "shard_pattern": "res://Assets/UI/item/hrro_suipian_{shard_id}.png", "ICON_SIZE": 232, "ITEM_SPACING": 60 },
      "note": "Phase16: 奖励道具水平排列(Control+position.x), 数字白字黑边(42px/outline10)叠加图标右下角(距边框30px), elastic入场动画"
    },
    "Scripts/Test/BattleTest.gd": {
      "ext": "Node2D",
      "r": "orchestrator",
      "c": { "wall_hp": 50 },
      "exp": ["current_stage_id"],
      "m": ["_setup_grid_map", "_setup_wave_director", "_load_stage_data", "_launch_wave_director", "_on_stage_victory", "_on_game_over", "_load_battle_ui", "_handle_effect_card", "_build_initial_card_pool", "_collect_effect_card_ids", "_deploy_squad_heroes", "_on_player_level_up", "_build_level_up_cards", "_update_hero_dim", "_dim_all_heroes_except", "_set_all_heroes_dimmed"],
      "note": "Phase18: _build_initial_card_pool从SaveManager读阵容→3x每英雄+效果卡; _deploy_squad_heroes预部署后排(i,4); _ready读SaveManager.selected_stage覆盖current_stage_id"
    }
  },
  "tscn": {
    "Scenes/BattleTest.tscn": { "s": "Scripts/Test/BattleTest.gd", "root": "Node2D", "ch": ["MapBackground"] },
    "Scenes/Hero.tscn": { "s": "Scripts/Entities/Hero.gd", "root": "Node2D", "ch": ["Sprite2D", "RayCast2D"] },
    "Scenes/Enemy.tscn": { "s": "Scripts/Entities/Enemy.gd", "root": "Area2D", "ch": ["Sprite2D", "CollisionShape2D", "HPBarRed", "HPBar"] },
    "Scenes/CardUI.tscn": { "s": "Scripts/UI/CardUI.gd", "root": "Control", "ch": ["CardBG(TextureRect)", "Icon", "Label"], "note": "Panel→CardBG: 动态加载rarity底图" },
    "Scenes/UI/BattleUI.tscn": { "s": "Scripts/UI/BattleUI.gd", "root": "CanvasLayer", "layer": 1, "ch": ["TopWrapper(HBoxContainer)", "Wall", "GridAnchor", "CardTrayAnchor(NinePatchRect)", "HandContainer", "RescueBanner", "DeckCountLabel"], "tiles": "Tile_1..Tile_25 under GridAnchor", "top_hud": "TopWrapper→RankNode(MedalBG+BattleLevel)+ExpBarNode(ExpProgressBar+ExpLabel)+PauseButton" },
    "Scenes/UI/PausePanel.tscn": { "s": "Scripts/UI/PausePanel.gd", "root": "CanvasLayer", "layer": 100, "ch": ["Background(ColorRect)", "ContentVBox(VBoxContainer)", "TitleLabel", "ButtonHBox(HBoxContainer)", "BtnHome", "BtnContinue"], "note": "半透明遮罩+居中内容, BtnContinue=取消暂停" },
    "Scenes/UI/VictoryPanel.tscn": { "s": "Scripts/UI/SettlementPanel.gd", "root": "CanvasLayer", "layer": 10, "ch": ["SafeAreaContainer(MarginContainer,lm=3)", "Wrapper(Control,lm=2,sf=3)", "Background(TextureRect,lm=2,sf=3)", "Label_Status(Label,lm=0)", "RewardContainer(Control,lm=0)", "Btn_Action(Button,lm=0)", "text(Label,lm=0)"], "note": "RewardContainer改为Control(lm=0), 代码水平排列道具+数字叠加" },
    "Scenes/UI/DefeatPanel.tscn": { "s": "Scripts/UI/SettlementPanel.gd", "root": "CanvasLayer", "layer": 10, "ch": ["SafeAreaContainer(MarginContainer,lm=3)", "Wrapper(Control,lm=2,sf=3)", "Background(TextureRect,lm=2,sf=3)", "Label_Status(Label,lm=0)", "RewardContainer(Control,lm=0)", "Btn_Action(Button,lm=0)", "text(Label,lm=0)"], "note": "结构100%对齐VictoryPanel, 仅text='失败'+defeat_color" },
    "Scenes/MainScene.tscn": { "s": "Scripts/UI/MainScene.gd", "root": "CanvasLayer", "ch": ["PanelContainer(full_rect)→SceneBg(ColorRect,dark)", "HomePanel→TitleLabel+SubtitleLabel+LevelSelect(BtnLevelLeft+LevelLabel+BtnLevelRight)+BtnStartBattle", "HeroPanel→SquadLabel+SquadContainer→Slot0~3(SlotBg+EmptyLabel+HeroIcon+QualityFrame)", "HeroPanel→HeroListLabel+HeroList(ScrollContainer,h=320,horiz)→HeroListContent(HBoxContainer,separation=20)", "PreloadPanels→ShopPanel+CampPanel+GuildPanel", "NavLayer(bottom,120px)→BottomNavBar→NavBarBg+BtnNav0(商店)+BtnNav1(英雄)+BtnNav2(战斗)+BtnNav3(阵营)+BtnNav4(公会)"], "note": "MainMenu: SceneBg暗色背景+HomePanel标题+关卡选择器+按钮; HeroPanel: SlotBg暗色占位+动态CardUI列表" }
  },
  "res": {
    "hero": {
      "path": "Assets/Heroes/hero_{sid}/hero_{sid}_{anim}_{idx}.png",
      "idmap": { "shielder_01": "001", "hero_002": "001", "hero_003": "001", "hero_004": "001" },
      "anims": { "standby": 4, "attack": 4, "deal": 4 },
      "list": ["hero_001"]
    },
    "enemy": {
      "path": "Assets/Monsters/monster_{mid}/monster{mid}_{anim}_{idx}.png",
      "mid": "01",
      "anims": { "move": 4, "attack": 4, "deal": 4 },
      "list": ["monster_01", "monster_02", "monster_03", "monster_04", "monster_05", "monster_06"]
    },
    "shader": { "hit_flash": "Assets/Shaders/hit_flash.gdshader" },
    "ui": { "wall": "Assets/UI/wall_001.png" },
    "bg": { "pat": "BattleMap/ui_BattleBG_pass_{n}.png", "n": [1, 5] },
    "tiles": { "pat": "Assets/UI/gezi/map_0{mid}/gezi_{n}.png", "mid": [1, 5], "n": [1, 25], "per_map": 25 }
  },
  "json": {
    "heroes_progression": "Data/heroes_progression.json",
    "battle_logic": "Data/battle_logic_config.json",
    "battle_map": "Data/battle_map.json",
    "error_codes": "Data/error_codes.json",
    "wall_config": "Data/wall_config.json",
    "battleMap_config": "Data/battleMap_config.json",
    "monster_templates": "Data/monster_templates.json",
    "level_stage_config": "Data/level_stage_config.json",
    "rarity_config": "Data/rarity_config.json",
    "card_display_config": "Data/card_display_config.json",
    "playerBattleEXP": "Data/playerBattleEXP.json",
    "card_actions_config": "Data/card_actions_config.json"
  },
  "build": {
    "export_presets": "export_presets.cfg (Android APK)",
    "note": "2026-05-11新增"
  },
  "flow": {
    "intercept": "Hero.try_intercept→RayCast2D→Enemy.set_paused(true)→both_ATTACK→Hero.frame2_deal_dmg; Enemy.attack_hit_signal→Hero.take_damage",
    "deploy": "CardUI.drag_ended→BattleTest._deploy_hero_from_card→BattleManager.apply_displacement(recursive_max5)→tween_0.25s",
    "deadlock": "DeckManager._physics_process(1s)→hand0+queue0+field0→rescue_pkg→GameEvents.deadlock_rescue_triggered→BattleUI.banner",
    "death": "HP≤0→DEATH_state→play_deal_frames_once→tween_fadeout→queue_free",
    "victory": "WaveDirector._check_victory(all_spawned+alive=0)→GameEvents.stage_victory→BattleTest._on_stage_victory→BattleManager.show_settlement(true)→VictoryPanel.tscn",
    "defeat": "BattleTest._trigger_game_over→GameEvents.game_over→BattleTest._on_game_over→BattleManager.show_settlement(false)→DefeatPanel.tscn",
    "settlement": "show_settlement→读DataManager.rewards→CanvasLayer+set_script→_build_ui代码构建→setup→动画→tween.finished→time_scale=0"
  },
  "pitfalls": {
    "title": "Godot开发规范/避坑指南",
    "rules": [
      {
        "id": "PIT-001",
        "tag": "UI挂载节点",
        "rule": "全局 VFX 的 CanvasLayer 绝对不能作为 Window/Autoload 的子节点。Autoload 是 Window 的直接子节点，不在 2D Viewport 渲染子树内，其子 CanvasLayer 不会渲染。必须挂载到 camera.get_parent()（即 2D Viewport 渲染子树内的节点，如 BattleTest）。",
        "code": "_damage_canvas = CanvasLayer.new(); camera.get_parent().add_child(_damage_canvas)"
      },
      {
        "id": "PIT-002",
        "tag": "坐标转换公式",
        "rule": "世界坐标转 UI 画布坐标，必须严格使用 get_canvas_transform().affine_inverse() * world_pos。canvas_transform 的方向是 canvas→world，取逆才是 world→canvas。绝不能用错矩阵方向，否则坐标完全偏移。",
        "code": "screen_pos = camera.get_canvas_transform().affine_inverse() * world_pos"
      },
      {
        "id": "PIT-003",
        "tag": "UI尺寸基准",
        "rule": "本项目设计高度 2160px。所有动态生成的 Label 文本字号基准不得小于 36px，描边 outline_size 至少为 3。若小于此基准，在高分辨率下文字肉眼不可见。",
        "code": "label.add_theme_font_size_override(\"font_size\", 36); label.add_theme_constant_override(\"outline_size\", 3)"
      }
    ]
  }
}
