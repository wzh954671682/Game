  "flow": {
    "intercept": "Hero.try_interceptРєњRayCast2DРєњEnemy.set_paused(true)Рєњboth_ATTACKРєњHero.frame2_deal_dmg; Enemy.attack_hit_signalРєњHero.take_damage",
    "deploy": "CardUI.drag_endedРєњBattleTest._deploy_hero_from_cardРєњBattleManager.apply_displacement(recursive_max5)Рєњtween_0.25s",
    "deadlock": "DeckManager._physics_process(1s)Рєњhand0+queue0+field0Рєњrescue_pkgРєњGameEvents.deadlock_rescue_triggeredРєњBattleUI.banner",
    "death": "HPРЅц0РєњDEATH_stateРєњplay_deal_frames_onceРєњtween_fadeoutРєњqueue_free",
    "victory": "WaveDirector._check_victory(all_spawned+alive=0)РєњGameEvents.stage_victoryРєњBattleTest._on_stage_victoryРєњBattleManager.show_settlement(true)РєњVictoryPanel.tscn",
    "defeat": "BattleTest._trigger_game_overРєњGameEvents.game_overРєњBattleTest._on_game_overРєњBattleManager.show_settlement(false)РєњDefeatPanel.tscn",
    "settlement": "show_settlementРєњУ»╗DataManager.rewardsРєњCanvasLayer+set_scriptРєњ_build_uiС╗БуаЂТъёт╗║РєњsetupРєњтіеућ╗Рєњtween.finishedРєњtime_scale=0"
  },
  "pitfalls": {
    "title": "Godotт╝ђтЈЉУДёУїЃ/жЂ┐тЮЉТїЄтЇЌ",
    "rules": [
      {
        "id": "PIT-001",
        "tag": "UIТїѓУййУіѓуѓ╣",
        "rule": "тЁет▒ђ VFX уџё CanvasLayer у╗Ют»╣СИЇУЃйСйюСИ║ Window/Autoload уџётГљУіѓуѓ╣сђѓAutoload Тў» Window уџёуЏ┤ТјЦтГљУіѓуѓ╣№╝їСИЇтюе 2D Viewport ТИ▓ТЪЊтГљТаЉтєЁ№╝їтЁХтГљ CanvasLayer СИЇС╝џТИ▓ТЪЊсђѓт┐ЁжА╗ТїѓУййтѕ░ camera.get_parent()№╝ѕтЇ│ 2D Viewport ТИ▓ТЪЊтГљТаЉтєЁуџёУіѓуѓ╣№╝їтдѓ BattleTest№╝Ѕсђѓ",
        "code": "_damage_canvas = CanvasLayer.new(); camera.get_parent().add_child(_damage_canvas)"
      },
      {
        "id": "PIT-002",
        "tag": "тЮљТаЄУйгТЇбтЁгт╝Ј",
        "rule": "СИќуЋїтЮљТаЄУйг UI ућ╗тИЃтЮљТаЄ№╝їт┐ЁжА╗СИЦТа╝Сй┐уће get_canvas_transform().affine_inverse() * world_posсђѓcanvas_transform уџёТќ╣тљЉТў» canvasРєњworld№╝їтЈќжђєТЅЇТў» worldРєњcanvasсђѓу╗ЮСИЇУЃйућежћЎуЪЕжўхТќ╣тљЉ№╝їтљдтѕЎтЮљТаЄт«їтЁетЂЈуД╗сђѓ",
        "code": "screen_pos = camera.get_canvas_transform().affine_inverse() * world_pos"
      },
      {
        "id": "PIT-003",
        "tag": "UIт░║т»ИтЪ║тЄє",
        "rule": "ТюгжА╣уЏ«У«ЙУ«АжФўт║д 2160pxсђѓТЅђТюЅтіеТђЂућЪТѕљуџё Label ТќЄТюгтГЌтЈитЪ║тЄєСИЇтЙЌт░ЈС║ј 36px№╝їТЈЈУЙ╣ outline_size УЄ│т░ЉСИ║ 3сђѓУІЦт░ЈС║јТГцтЪ║тЄє№╝їтюежФўтѕєУЙеујЄСИІТќЄтГЌУѓЅую╝СИЇтЈ»УДЂсђѓ",
        "code": "label.add_theme_font_size_override(\"font_size\", 36); label.add_theme_constant_override(\"outline_size\", 3)"
      }
    ]
  }
}
