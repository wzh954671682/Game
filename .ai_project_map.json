{
  "v": 1,
  "engine": "godot4.6",
  "name": "GameDemo-w",
  "resolution": [1080, 2160],
  "dirs": {
    "scripts": "Scripts",
    "scenes": "Scenes",
    "assets": "Assets",
    "data": "Data",
    "maps": "BattleMap",
    "docs": "Docs",
    "tools": "Tools"
  },
  "al": [
    {"n": "GameEvents", "f": "Scripts/Global/GameEvents.gd", "r": "sigbus"},
    {"n": "GridManager", "f": "Scripts/Logic/GridManager.gd", "r": "grid"},
    {"n": "DataManager", "f": "Scripts/Global/DataManager.gd", "r": "json"},
    {"n": "BattleManager", "f": "Scripts/Managers/BattleManager.gd", "r": "occ"},
    {"n": "DeckManager", "f": "Scripts/Managers/DeckManager.gd", "r": "deck"},
    {"n": "VFXManager", "f": "Scripts/Global/VFXManager.gd", "r": "vfx"},
    {"n": "SaveManager", "f": "Scripts/Global/SaveManager.gd", "r": "save"}
  ],
  "gd": {
    "Scripts/Entities/Hero.gd": {
      "ext": "Node2D",
      "fsm": ["STANDBY", "ATTACK", "DEATH"],
      "exp": ["hero_id", "current_star", "max_block_count", "attack_power", "max_health", "frame_interval"],
      "sig": [],
      "m": ["try_intercept", "take_damage", "can_star_up", "star_up", "init_hero", "set_paused", "get_final_stats"],
      "stars": { "max": 5, "mult": [1.0, 1.5, 2.2, 3.0, 4.5], "scale": 0.1, "heal": 0.2 },
      "z": { "default": 0 },
      "note": "Phase15.5: get_final_stats(stat)→(base+meta)*(1+star_bonus)*(1+buff_bonus)"
    },
    "Scripts/Entities/Enemy.gd": {
      "ext": "Area2D",
      "fsm": ["MOVE", "ATTACK", "DEATH"],
      "exp": ["move_speed", "max_health", "wall_damage", "attack_damage", "monster_id", "frame_interval", "is_elite", "is_boss"],
      "sig": ["attack_hit"],
      "m": ["take_damage", "set_paused", "_setup_hp_bars"],
      "z": { "default": 0 },
      "note": "Phase15.5: 双层残影HPBar(HPBar+HPBarRed), elite/boss可见, take_damage瞬扣+Tween0.4s追平"
    },
    "Scripts/Global/GameEvents.gd": {
      "ext": "Node",
      "sig": ["wall_hit", "enemy_died", "card_deployed", "deadlock_rescue_triggered", "wall_hp_changed", "game_over", "stage_victory"]
    },
    "Scripts/Global/DataManager.gd": { "ext": "Node", "m": ["load_json"], "exp": ["error_messages", "monster_templates", "stage_config", "wall_config", "rarity_config", "card_display_config", "heroes_progression"] },
    "Scripts/Global/SaveManager.gd": { "ext": "Node", "m": ["save_game", "load_game"], "exp": ["save_data(gold/shards/max_level/unlocked_cards)"] },
    "Scripts/Global/VFXManager.gd": { "ext": "Node", "m": ["hit_stop", "show_damage_text"], "note": "PROCESS_MODE_ALWAYS; Phase15.5: is_crit参数(黄字/1.5x字号/弹性缩放), 防堆叠(POPUP_MAX=15, >5屏偏移)", "z": { "damage_text": 20, "damage_canvas_layer": 100 } },
    "Scripts/Logic/GridManager.gd": {
      "ext": "Node",
      "m": ["get_screen_pos", "get_logic_pos", "get_wall_boundary", "get_card_tray_top", "apply_scene_layout", "set_grid_anchor_pos", "get_grid_center", "setup_map", "load_battle_map", "load_map_async", "get_tile_node", "get_tile_for_grid_pos"],
      "c": { "cols": 5, "rows": 5, "cell": 190, "rw": 1080, "rh": 2160, "tile_count": 25, "tile_z_index": -5 }
    },
    "Scripts/Managers/BattleManager.gd": {
      "ext": "Node",
      "m": ["apply_displacement", "register_entity", "unregister_entity", "get_hero_at", "_on_displacement_finished", "show_settlement"],
      "c": { "max_recurse": 5, "tween_dur": 0.25 },
      "exp": ["current_stage_id"],
      "note": "Phase16: show_settlement→load .tscn→setup→动画→tween.finished→time_scale=0"
    },
    "Scripts/Logic/WaveDirector.gd": {
      "ext": "Node",
      "r": "wave",
      "m": ["load_stage_script", "get_map_id", "is_last_wave", "is_active"],
      "exp": [],
      "sig": [],
      "c": {}
    },
    "Scripts/Managers/DeckManager.gd": {
      "ext": "Node",
      "sig": ["card_drawn"],
      "c": { "max_hand": 5, "rescue_cd": 10, "draw_interval": 0.1, "scan_interval": 1.0, "init_silence": 5.0 },
      "m": ["start_battle"]
    },
    "Scripts/UI/BattleUI.gd": { "ext": "CanvasLayer", "m": ["update_exp", "update_battle_level", "_on_pause_pressed"], "exp": ["_medal_bg", "_battle_level_label", "_exp_progress_bar", "_exp_label", "_pause_button", "_pause_panel"], "note": "TopWrapper子节点引用+暂停面板加载" },
    "Scripts/UI/PausePanel.gd": { "ext": "CanvasLayer", "m": ["show_pause", "_on_continue_pressed", "_on_home_pressed"], "note": "暂停弹窗: 遮罩+继续(取消暂停)+首页(预留)" },
    "Scripts/UI/CardTrayManager.gd": { "ext": "Control", "cn": "CardTrayManager", "sig": ["card_created"], "m": ["setup"] },
    "Scripts/UI/CardUI.gd": { "ext": "Control", "sig": ["drag_started", "drag_ended", "drag_cancelled"], "m": ["setup_card", "setup"], "z": { "idle": 0, "dragging": 10, "selected": 10 }, "note": "数据驱动: setup_card()→rarity_config+card_display_config→动态加载CardBG/Icon/Label" },
    "Scripts/UI/SafeAreaContainer.gd": { "ext": "MarginContainer" },
    "Scripts/UI/WrapperMonitor.gd": { "ext": "Control", "note": "Debug: 监控Wrapper节点size/position变化并打印日志" },
    "Scripts/UI/SettlementPanel.gd": {
      "ext": "CanvasLayer",
      "m": ["setup", "_play_entrance_animation", "_create_reward_icons", "_save_rewards", "_on_btn_action_pressed"],
      "exp": ["panel_width", "panel_height", "status_font_size", "reward_font_size", "button_font_size", "icon_size", "icon_spacing", "icon_bounce_delay", "entrance_duration", "icon_bounce_duration", "initial_delay", "victory_color", "defeat_color", "overlay_color", "gold_color", "shard_color"],
      "c": { "coin_icon": "Assets/UI/item/jinbi.png", "shard_pattern": "res://Assets/UI/item/hrro_suipian_{shard_id}.png" },
      "note": "Phase16: 结算弹窗, @export变量驱动布局, modulate+slide入场(不依赖scale), Timer触发freeze, ClickBlocker防穿透"
    },
    "Scripts/Test/BattleTest.gd": {
      "ext": "Node2D",
      "r": "orchestrator",
      "c": { "wall_hp": 50 },
      "exp": ["current_stage_id"],
      "m": ["_setup_grid_map", "_setup_wave_director", "_load_stage_data", "_launch_wave_director", "_on_stage_victory", "_on_game_over", "_load_battle_ui"],
      "note": "GridAnchor runtime-reparent: CanvasLayer→Node2D; Phase16: victory/defeat→BattleManager.show_settlement"
    }
  },
  "tscn": {
    "Scenes/BattleTest.tscn": { "s": "Scripts/Test/BattleTest.gd", "root": "Node2D", "ch": ["MapBackground"] },
    "Scenes/Hero.tscn": { "s": "Scripts/Entities/Hero.gd", "root": "Node2D", "ch": ["Sprite2D", "RayCast2D"] },
    "Scenes/Enemy.tscn": { "s": "Scripts/Entities/Enemy.gd", "root": "Area2D", "ch": ["Sprite2D", "CollisionShape2D", "HPBarRed", "HPBar"] },
    "Scenes/CardUI.tscn": { "s": "Scripts/UI/CardUI.gd", "root": "Control", "ch": ["CardBG(TextureRect)", "Icon", "Label"], "note": "Panel→CardBG: 动态加载rarity底图" },
    "Scenes/UI/BattleUI.tscn": { "s": "Scripts/UI/BattleUI.gd", "root": "CanvasLayer", "layer": 1, "ch": ["TopWrapper(HBoxContainer)", "Wall", "GridAnchor", "CardTrayAnchor(NinePatchRect)", "HandContainer", "RescueBanner", "DeckCountLabel"], "tiles": "Tile_1..Tile_25 under GridAnchor", "top_hud": "TopWrapper→RankNode(MedalBG+BattleLevel)+ExpBarNode(ExpProgressBar+ExpLabel)+PauseButton" },
    "Scenes/UI/PausePanel.tscn": { "s": "Scripts/UI/PausePanel.gd", "root": "CanvasLayer", "layer": 100, "ch": ["Background(ColorRect)", "ContentVBox(VBoxContainer)", "TitleLabel", "ButtonHBox(HBoxContainer)", "BtnHome", "BtnContinue"], "note": "半透明遮罩+居中内容, BtnContinue=取消暂停" },
    "Scenes/UI/VictoryPanel.tscn": { "s": "Scripts/UI/SettlementPanel.gd", "root": "CanvasLayer", "layer": 10, "ch": ["SafeAreaContainer(MarginContainer,lm=3)", "Wrapper(Control,lm=2,sf=3)", "Background(TextureRect,lm=2,sf=3)", "Label_Status(Label,lm=2)", "RewardContainer(VBoxContainer,lm=2,sf=3)", "Btn_Action(Button,lm=2)", "text(Label,lm=2)"], "note": "Container Dominance: 容器子节点全用layout_mode=2+size_flags, 无anchor/offset残留" },
    "Scenes/UI/DefeatPanel.tscn": { "s": "Scripts/UI/SettlementPanel.gd", "root": "CanvasLayer", "layer": 10, "ch": ["SafeAreaContainer(MarginContainer,lm=3)", "Wrapper(Control,lm=2,sf=3)", "Background(TextureRect,lm=2,sf=3)", "Label_Status(Label,lm=2)", "RewardContainer(VBoxContainer,lm=2,sf=3)", "Btn_Action(Button,lm=2)", "text(Label,lm=2)"], "note": "结构100%对齐VictoryPanel, 仅text='失败'+defeat_color" }
  },
  "res": {
    "hero": {
      "path": "Assets/Heroes/hero_{sid}/hero_{sid}_{anim}_{idx}.png",
      "idmap": { "shielder_01": "001", "gunner_01": "001" },
      "anims": { "standby": 4, "attack": 4, "deal": 4 },
      "list": ["hero_001"]
    },
    "enemy": {
      "path": "Assets/Monsters/monster_{mid}/monster{mid}_{anim}_{idx}.png",
      "mid": "01",
      "anims": { "move": 4, "attack": 4, "deal": 4 },
      "list": ["monster_01"]
    },
    "shader": { "hit_flash": "Assets/Shaders/hit_flash.gdshader" },
    "ui": { "wall": "Assets/UI/wall_001.png" },
    "bg": { "pat": "BattleMap/ui_BattleBG_pass_{n}.png", "n": [1, 5] },
    "tiles": { "pat": "Assets/UI/gezi/map_0{mid}/gezi_{n}.png", "mid": [1, 5], "n": [1, 25], "per_map": 25 }
  },
  "json": {
    "heroes_progression": "Data/heroes_progression.json",
    "battle_logic": "Data/battle_logic_config.json",
    "battle_map": "Data/battle_map.json",
    "error_codes": "Data/error_codes.json",
    "wall_config": "Data/wall_config.json",
    "battleMap_config": "Data/battleMap_config.json",
    "monster_templates": "Data/monster_templates.json",
    "level_stage_config": "Data/level_stage_config.json",
    "rarity_config": "Data/rarity_config.json",
    "card_display_config": "Data/card_display_config.json",
    "playerBattleEXP": "Data/playerBattleEXP.json"
  },
  "flow": {
    "intercept": "Hero.try_intercept→RayCast2D→Enemy.set_paused(true)→both_ATTACK→Hero.frame2_deal_dmg; Enemy.attack_hit_signal→Hero.take_damage",
    "deploy": "CardUI.drag_ended→BattleTest._deploy_hero_from_card→BattleManager.apply_displacement(recursive_max5)→tween_0.25s",
    "deadlock": "DeckManager._physics_process(1s)→hand0+queue0+field0→rescue_pkg→GameEvents.deadlock_rescue_triggered→BattleUI.banner",
    "death": "HP≤0→DEATH_state→play_deal_frames_once→tween_fadeout→queue_free",
    "victory": "WaveDirector._check_victory(all_spawned+alive=0)→GameEvents.stage_victory→BattleTest._on_stage_victory→BattleManager.show_settlement(true)→VictoryPanel.tscn",
    "defeat": "BattleTest._trigger_game_over→GameEvents.game_over→BattleTest._on_game_over→BattleManager.show_settlement(false)→DefeatPanel.tscn",
    "settlement": "show_settlement→读DataManager.rewards→CanvasLayer+set_script→_build_ui代码构建→setup→动画→tween.finished→time_scale=0"
  },
  "pitfalls": {
    "title": "Godot开发规范/避坑指南",
    "rules": [
      {
        "id": "PIT-001",
        "tag": "UI挂载节点",
        "rule": "全局 VFX 的 CanvasLayer 绝对不能作为 Window/Autoload 的子节点。Autoload 是 Window 的直接子节点，不在 2D Viewport 渲染子树内，其子 CanvasLayer 不会渲染。必须挂载到 camera.get_parent()（即 2D Viewport 渲染子树内的节点，如 BattleTest）。",
        "code": "_damage_canvas = CanvasLayer.new(); camera.get_parent().add_child(_damage_canvas)"
      },
      {
        "id": "PIT-002",
        "tag": "坐标转换公式",
        "rule": "世界坐标转 UI 画布坐标，必须严格使用 get_canvas_transform().affine_inverse() * world_pos。canvas_transform 的方向是 canvas→world，取逆才是 world→canvas。绝不能用错矩阵方向，否则坐标完全偏移。",
        "code": "screen_pos = camera.get_canvas_transform().affine_inverse() * world_pos"
      },
      {
        "id": "PIT-003",
        "tag": "UI尺寸基准",
        "rule": "本项目设计高度 2160px。所有动态生成的 Label 文本字号基准不得小于 36px，描边 outline_size 至少为 3。若小于此基准，在高分辨率下文字肉眼不可见。",
        "code": "label.add_theme_font_size_override(\"font_size\", 36); label.add_theme_constant_override(\"outline_size\", 3)"
      }
    ]
  }
}
